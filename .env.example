# Database
# Local SQLite (default — DATABASE_URL is optional, defaults to file:./prisma/dev.db)
# DATABASE_URL="file:./prisma/dev.db"
# For cloud persistence use Turso: https://turso.tech
# DATABASE_URL="libsql://your-db-name-your-org.turso.io"
# DATABASE_AUTH_TOKEN="your_turso_auth_token_here"

# AI Provider — LLM for synthesizing answers
# Options: gemini (default), openai, ollama
AI_PROVIDER=gemini
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-2.0-flash
# OPENAI_API_KEY=your_openai_api_key_here
# OLLAMA_BASE_URL=http://localhost:11434

# Embeddings — used for indexing and search
# Options: local (default, offline ~80MB model), gemini, openai
EMBEDDINGS_PROVIDER=local

# Logging
NODE_ENV=development
LOG_LEVEL=info
LOG_TO_FILE=false
LOG_DIR=logs

# Monitoring (optional)
# SENTRY_DSN=your_sentry_dsn_here
