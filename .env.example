# Database (Turso — required on Vercel; use file: URL only for local dev)
# Create a free database at https://turso.tech
DATABASE_URL="libsql://your-db-name-your-org.turso.io"
DATABASE_AUTH_TOKEN="your_turso_auth_token_here"

# AI Provider
# Get your Google API key at https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here
AI_PROVIDER=gemini
GEMINI_MODEL=gemini-2.0-flash

# External API Authentication (generate secure random strings for production)
API_SECRET_KEY=your_secure_random_string_here
ADMIN_API_KEY=your_secure_random_string_here

# Application Settings
NEXT_PUBLIC_MAX_FILE_SIZE=10485760
NODE_ENV=production

# Logging
LOG_LEVEL=info
LOG_TO_FILE=false
LOG_DIR=logs

# Monitoring (optional)
# SENTRY_DSN=your_sentry_dsn_here
# SENTRY_TRACES_SAMPLE_RATE=0.1
